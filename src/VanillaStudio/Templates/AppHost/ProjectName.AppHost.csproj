{{AspireProjectOpenTag}}

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>{{TargetFramework}}</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <UserSecretsId>{{UserSecretsId}}</UserSecretsId>
  </PropertyGroup>

{{AspirePackageGroup}}

  <ItemGroup>
    <ProjectReference Include="..\{{ProjectName}}.WebAPI\{{ProjectName}}.WebAPI.csproj" />
    <ProjectReference Include="..\{{ProjectName}}.WebPortal\{{ProjectName}}.WebPortal\{{ProjectName}}.WebPortal.csproj" />
  </ItemGroup>

</Project>
