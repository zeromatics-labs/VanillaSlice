{
  "name": "vanillastudio-landing",
  "version": "1.0.0",
  "private": true,
  "description": "Tailwind CSS build for the VanillaStudio landing page (scoped to / only)",
  "scripts": {
    "build-css": "tailwindcss -i ./Styles/app.css -o ./wwwroot/css/app-tailwind.css --watch",
    "build-css-prod": "tailwindcss -i ./Styles/app.css -o ./wwwroot/css/app-tailwind.css --minify"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17"
  }
}
