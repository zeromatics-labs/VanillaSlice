@page "/"
@using System.Text.Json
@using ZKnow.VanillaStudio.Components.Pages.Landing

<PageTitle>VanillaSlice — Free Vertical Slice & Clean Architecture Templates for .NET (Blazor & MAUI)</PageTitle>

<HeadContent>
    <meta name="description" content="VanillaSlice is a free, open-source code generator for .NET that scaffolds vertical-slice, clean-architecture features for Blazor Web and MAUI. Full source, MIT licensed, no lock-in." />
    <meta name="keywords" content="vertical slice architecture, clean architecture, .NET templates, Blazor templates, MAUI templates, free code generator, SOLID, open source, C#, CRUD scaffolding" />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="VanillaSlice" />
    <link rel="canonical" href="https://vanillaslice.dev/" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="VanillaSlice" />
    <meta property="og:title" content="VanillaSlice — Free Vertical Slice & Clean Architecture Templates for .NET" />
    <meta property="og:description" content="A free, open-source code generator for .NET. Scaffold vertical-slice, clean-architecture features for Blazor Web and MAUI. Full source, MIT, no lock-in." />
    <meta property="og:url" content="https://vanillaslice.dev/" />
    <meta property="og:image" content="https://vanillaslice.dev/og-image.png" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="VanillaSlice — Free Vertical Slice & Clean Architecture Templates for .NET" />
    <meta name="twitter:description" content="A free, open-source code generator for .NET. Scaffold vertical-slice, clean-architecture features for Blazor Web and MAUI. Full source, MIT, no lock-in." />
    <meta name="twitter:image" content="https://vanillaslice.dev/og-image.png" />

    @((MarkupString)$"<script type=\"application/ld+json\">{SoftwareAppJsonLd}</script>")
    @((MarkupString)$"<script type=\"application/ld+json\">{FaqJsonLd}</script>")
</HeadContent>

<div class="font-sans text-ink">

    <HeroSection />

    @* Assurance strip *@
    <div class="border-b border-paper-line bg-paper-2">
        <div class="mx-auto flex max-w-page flex-wrap items-center justify-center gap-x-8 gap-y-2 px-6 py-4 font-mono text-xs uppercase tracking-kicker text-dim-2">
            <span>100% free</span>
            <span class="text-paper-line">·</span>
            <span>MIT licensed</span>
            <span class="text-paper-line">·</span>
            <span>full source included</span>
            <span class="text-paper-line">·</span>
            <span>no runtime dependency</span>
            <span class="text-paper-line">·</span>
            <span>nothing to monetize, ever</span>
        </div>
    </div>

    @* Architecture — asymmetric: intro column + principle cells *@
    <section id="architecture" class="mx-auto max-w-page px-6 py-24">
        <div class="grid gap-12 lg:grid-cols-[0.85fr_1.15fr] lg:gap-16">
            <div>
                <p class="kicker mb-4">// why vertical slices</p>
                <h2 class="font-display text-4xl font-extrabold leading-[1.08] text-ink">
                    Clean architecture, organized as vertical slices.
                </h2>
                <p class="mt-5 leading-relaxed text-dim-2">
                    Instead of scattering one feature across controller, service, and UI folders,
                    each slice owns its whole vertical: UI → contract → domain → data. SOLID by
                    design — features stay independent, easy to test, and safe to change.
                </p>
            </div>
            <div class="grid gap-5 sm:grid-cols-3">
                <FeatureCard Tag="structure" Title="Self-contained slices"
                             Body="Every feature ships with its Razor/XAML UI, ViewModel, typed client, controller, and server service — owned end-to-end." />
                <FeatureCard Tag="principle" Title="SOLID by default"
                             Body="The factory enforces structure through interfaces and safe stubs, so you write domain logic — not plumbing." />
                <FeatureCard Tag="longevity" Title="Absorbs .NET evolution"
                             Body="Thin, feature-centric slices keep regressions low and let your codebase grow with the platform and AI co-authoring." />
            </div>
        </div>
    </section>

    @* How it works — a real pipeline *@
    <section class="border-y border-paper-line bg-paper-2">
        <div class="mx-auto max-w-page px-6 py-24">
            <p class="kicker mb-4">// pipeline</p>
            <h2 class="max-w-2xl font-display text-4xl font-extrabold leading-[1.08] text-ink">
                From idea to a runnable solution in three steps.
            </h2>
            <div class="mt-14 grid gap-10 md:grid-cols-3">
                <StepCard Number="1" Title="Configure in the wizard"
                          Body="Pick your platform (Blazor Web or Web + MAUI), UI framework, database, and auth. No setup, no install." />
                <StepCard Number="2" Title="Generate the solution"
                          Body="Download a complete, pre-wired solution — projects, DI, routing, endpoints, and sample CRUD slices included." />
                <StepCard Number="3" Title="Own &amp; tweak every line"
                          Body="It's plain C#. Add fields, implement queries, and ship. There's no SDK between you and your code." />
            </div>
        </div>
    </section>

    @* Features — spec-sheet grid *@
    <section id="features" class="mx-auto max-w-page px-6 py-24">
        <p class="kicker mb-4">// what you get</p>
        <h2 class="max-w-2xl font-display text-4xl font-extrabold leading-[1.08] text-ink">
            Batteries included, your choice of stack.
        </h2>
        <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
            <FeatureCard Tag="platform" Title="Blazor Web" Status="ready"
                         Body="Server-side and WebAssembly rendering with configurable render modes." />
            <FeatureCard Tag="platform" Title="MAUI Hybrid" Status="ready"
                         Body="Cross-platform mobile from the same shared Razor components." />
            <FeatureCard Tag="platform" Title="MAUI Native" Status="ready"
                         Body="Native XAML frontend over the same shared backend slices." />
            <FeatureCard Tag="ui" Title="UI Frameworks" Status="ready"
                         Body="Bootstrap 5, Microsoft Fluent UI, and Tailwind CSS implemented out of the box." />
            <FeatureCard Tag="data" Title="Database & EF Core" Status="ready"
                         Body="SQL Server with Entity Framework Core — migrations, seeding, and the repository pattern." />
            <FeatureCard Tag="security" Title="Auth & Security" Status="ready"
                         Body="ASP.NET Core Identity, authorization policies, and JWT token support." />
        </div>
    </section>

    @* Confidence — bold typographic statement on ink *@
    <section class="bg-ink text-paper">
        <div class="mx-auto max-w-page px-6 py-24">
            <p class="kicker-dim mb-5">// the promise</p>
            <h2 class="max-w-3xl font-display text-4xl font-extrabold leading-[1.06] text-paper sm:text-5xl">
                It's code that generates code — then <span class="text-signal">gets out of your way.</span>
            </h2>
            <div class="mt-14 grid gap-px border border-line bg-line sm:grid-cols-2">
                @foreach (var (n, text) in Promises)
                {
                    <div class="flex gap-4 bg-ink p-7">
                        <span class="font-mono text-sm text-signal-600">@n</span>
                        <p class="leading-relaxed text-dim">@text</p>
                    </div>
                }
            </div>
        </div>
    </section>

    @* FAQ *@
    <section id="faq" class="mx-auto max-w-3xl px-6 py-24">
        <p class="kicker mb-4">// faq</p>
        <h2 class="font-display text-4xl font-extrabold text-ink">Questions, answered.</h2>
        <div class="mt-10 border-t border-paper-line">
            @foreach (var f in Faqs)
            {
                <FaqItem Question="@f.Question" Answer="@f.Answer" />
            }
        </div>
    </section>

    @* Final CTA + footer on ink *@
    <section class="bg-ink text-paper">
        <div class="mx-auto max-w-page px-6 py-24 text-center">
            <p class="kicker-dim mb-5">// ready</p>
            <h2 class="font-display text-4xl font-extrabold text-paper sm:text-5xl">Generate your project.</h2>
            <p class="mx-auto mt-4 max-w-md text-dim">Free, in your browser, no sign-up. You'll have a runnable solution in minutes.</p>
            <div class="mt-9 flex justify-center">
                <a href="/wizard" class="btn-signal">
                    Start the wizard
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </a>
            </div>
        </div>
        <footer class="border-t border-line">
            <div class="mx-auto flex max-w-page flex-col items-center justify-between gap-5 px-6 py-8 sm:flex-row">
                <a href="/" class="flex items-center gap-2.5 font-display font-extrabold text-paper">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <rect x="3" y="3" width="18" height="4" rx="1" fill="#E2795B" />
                        <rect x="3" y="10" width="18" height="4" rx="1" fill="#5B7D99" />
                        <rect x="3" y="17" width="18" height="4" rx="1" fill="#FFC24B" />
                    </svg>
                    VanillaSlice
                </a>
                <div class="flex flex-wrap items-center gap-6 font-mono text-sm text-dim">
                    <a class="transition-colors hover:text-paper" href="@GitHubUrl" target="_blank" rel="noopener">github</a>
                    <a class="transition-colors hover:text-paper" href="@($"{GitHubUrl}/releases")" target="_blank" rel="noopener">releases</a>
                    <a class="transition-colors hover:text-paper" href="@($"{GitHubUrl}/blob/main/LICENSE")" target="_blank" rel="noopener">license</a>
                    <a class="transition-colors hover:text-paper" href="/wizard">generate</a>
                </div>
                <p class="font-mono text-xs text-dim">MIT · free &amp; open-source</p>
            </div>
        </footer>
    </section>

</div>

@code {
    private const string GitHubUrl = "https://github.com/zero-know/VanillaSlice";

    private static readonly (string n, string text)[] Promises = new[]
    {
        ("01", "No runtime SDK, package, or service dependency — the generated code is fully standalone."),
        ("02", "MIT licensed, full source on GitHub — fork it, audit it, change anything."),
        ("03", "Use the generated code commercially with zero obligations."),
        ("04", "No accounts, no telemetry paywall, no \"pro tier\" — and no plan to add one.")
    };

    private record Faq(string Question, string Answer);

    private static readonly Faq[] Faqs = new[]
    {
        new Faq("Is VanillaSlice really free?",
            "Yes. It is open-source under the MIT License, with the full source available on GitHub. There is no paid tier, no account, and no usage limit."),
        new Faq("What is vertical slice architecture?",
            "Vertical slice architecture organizes code by feature rather than by technical layer. Each slice contains everything one feature needs — UI, contracts, domain logic, and data access — so features stay independent and easy to change."),
        new Faq("Do I depend on VanillaSlice at runtime?",
            "No. VanillaSlice generates plain C# source code into your solution. Once generated, your project has no dependency on VanillaSlice — it runs entirely on standard .NET."),
        new Faq("Can I use the generated code commercially?",
            "Absolutely. The MIT License lets you use, modify, and distribute the generated code in commercial products with no obligations."),
        new Faq("Will VanillaSlice ever be monetized?",
            "No. The generated code is standalone and there is no runtime service to charge for. The project is open-source by design, with nothing to lock you in.")
    };

    // Use the default (HTML-safe) encoder so that <, >, & are escaped to \uXXXX,
    // keeping the inline JSON-LD block safe against </script> injection.
    private static readonly JsonSerializerOptions JsonSeoOptions = new();

    private const string SoftwareAppJsonLd = @"{
  ""@context"": ""https://schema.org"",
  ""@type"": ""SoftwareApplication"",
  ""name"": ""VanillaSlice"",
  ""description"": ""A free, open-source code generator for .NET that scaffolds vertical-slice, clean-architecture features for Blazor Web and MAUI."",
  ""applicationCategory"": ""DeveloperApplication"",
  ""operatingSystem"": ""Windows, macOS, Linux"",
  ""url"": ""https://vanillaslice.dev/"",
  ""license"": ""https://opensource.org/licenses/MIT"",
  ""sameAs"": ""https://github.com/zero-know/VanillaSlice"",
  ""offers"": { ""@type"": ""Offer"", ""price"": ""0"", ""priceCurrency"": ""USD"" }
}";

    private string FaqJsonLd => JsonSerializer.Serialize(new Dictionary<string, object?>
    {
        ["@context"] = "https://schema.org",
        ["@type"] = "FAQPage",
        ["mainEntity"] = Faqs.Select(f => new Dictionary<string, object?>
        {
            ["@type"] = "Question",
            ["name"] = f.Question,
            ["acceptedAnswer"] = new Dictionary<string, object?>
            {
                ["@type"] = "Answer",
                ["text"] = f.Answer
            }
        }).ToArray()
    }, JsonSeoOptions);
}
